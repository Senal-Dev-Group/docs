        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "Auth",
            "pages": [
              "api-reference/auth/create-api-key",
              "api-reference/auth/derive-api-key"
            ]
          },
          {
            "group": "Orders",
            "pages": [
              "api-reference/orders/place-order",
              "api-reference/orders/batch-place",
              "api-reference/orders/get-orders",
